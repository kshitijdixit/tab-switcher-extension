{
  "manifest_version": 3,
  "name": "Tab Switcher",
  "version": "1.3",
  "description": "Switch to existing tabs instead of opening duplicates. Cmd+Alt+Click to force new tab.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Switcher Settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
