{
  "manifest_version": 3,
  "name": "Tab Switcher",
  "version": "2.0",
  "description": "Switch to existing tabs instead of opening duplicates",
  "permissions": [
    "tabs",
    "storage",
    "notifications"
  ],
  "icons": {
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Switcher Settings",
    "default_icon": "icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "bypass-next": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Open next link in new tab (bypass duplicate check)"
    },
    "scan-duplicates": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac": "Alt+Shift+D"
      },
      "description": "Scan and close duplicate tabs"
    }
  }
}
