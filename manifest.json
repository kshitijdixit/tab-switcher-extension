{
  "manifest_version": 3,
  "name": "Tab Switcher",
  "version": "1.4",
  "description": "Switch to existing tabs instead of opening duplicates",
  "permissions": [
    "tabs",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Switcher Settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "bypass-next": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Open next link in new tab (bypass duplicate check)"
    }
  }
}
